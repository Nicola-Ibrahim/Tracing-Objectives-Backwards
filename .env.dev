# ==========================================
# Tracing Objectives Backwards - Local Development
# ==========================================

# API Versioning (Change once to update entire stack)
API_VERSION=v1

# Backend Settings
PYTHONUNBUFFERED=1
VIRTUAL_ENV=/opt/venv
UV_PROJECT_ENVIRONMENT=/opt/venv
DATA_STORAGE_PATH=/app

# Frontend Settings (NEXT_PUBLIC_ variables are exposed to the browser)
NODE_ENV=development
NEXT_PUBLIC_API_URL=/api
NEXT_PUBLIC_API_VERSION=v1
# Use http://localhost (port 80) to go through Nginx gateway for all services
INTERNAL_API_URL=http://localhost
