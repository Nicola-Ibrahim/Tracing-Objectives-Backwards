# ==========================================
# Tracing Objectives Backwards - Backend Dev
# ==========================================

# Project Settings
PROJECT_NAME="Tracing Objectives Backwards API"
API_VERSION=v1

# Security
SECRET_KEY=dev-secret-key-12345

# Infrastructure
ENV=development
DEBUG=true
BACKEND_CORS_ORIGINS=http://localhost,http://localhost:3000

# Storage
PYTHONUNBUFFERED=1
VIRTUAL_ENV=/opt/venv
UV_PROJECT_ENVIRONMENT=/opt/venv
DATA_STORAGE_PATH=/app

# Operations
LOG_LEVEL=DEBUG
