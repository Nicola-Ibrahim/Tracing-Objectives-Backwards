# ==========================================
# Tracing Objectives Backwards - Consolidated Backend Env
# ==========================================

# --- API Settings ---
PROJECT_NAME="Tracing Objectives Backwards API"

# --- Security ---
# Secret key for JWT/Session signing (REQUIRED in production)
# Generate with: openssl rand -hex 32
SECRET_KEY=2cd502f83175b236a6d16e5bbb4e19453e487286f2fab18f2aaaa9c1668347a2

# --- Infrastructure ---
# Environment: development, production, testing
ENV=development
DEBUG=true
# Use * for development or specific origins for production
BACKEND_CORS_ORIGINS=http://localhost,http://localhost:3000

# --- Docker / Compose Infrastructure ---
# Used by docker-compose.dev.yml
BACKEND_IMAGE=my-local-backend:latest
REDIS_URL=redis://redis:6379/0

# --- Logging / Debugging ---
# Level: DEBUG, INFO, WARNING, ERROR, CRITICAL
LOG_LEVEL=DEBUG
PYTHONASYNCIODEBUG=1
PYTHONPATH=/app
