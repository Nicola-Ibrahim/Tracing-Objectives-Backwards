# ==========================================
# Tracing Objectives Backwards - Backend Env
# ==========================================

# --- API Settings ---
# Project branding
PROJECT_NAME="Tracing Objectives Backwards API"
# API version slug (e.g., v1, v2)
API_VERSION=v1

# --- Security ---
# Secret key for JWT/Session signing (REQUIRED in production)
# Generate with: openssl rand -hex 32
SECRET_KEY=dev-secret-key-12345

# --- Infrastructure ---
# Environment: development, production, testing
ENV=development
# Debug mode (true/false)
DEBUG=true
# Allowed CORS origins (comma-separated)
BACKEND_CORS_ORIGINS=http://localhost,http://localhost:3000

# --- Storage ---
# Path for datasets and models
PYTHONUNBUFFERED=1
VIRTUAL_ENV=/opt/venv
UV_PROJECT_ENVIRONMENT=/opt/venv
DATA_STORAGE_PATH=/app

# --- Logging ---
# Level: DEBUG, INFO, WARNING, ERROR, CRITICAL
LOG_LEVEL=DEBUG
