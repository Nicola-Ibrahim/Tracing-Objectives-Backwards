# ==========================================
# Tracing Objectives Backwards - Backend Env Template
# ==========================================

# --- API Settings ---
PROJECT_NAME="Tracing Objectives Backwards API"

# --- Security ---
# Secret key for JWT/Session signing (REQUIRED)
# Generate with: openssl rand -hex 32
SECRET_KEY=temporary-secret-key-for-dev

# --- Infrastructure ---
# Environment: development, production (REQUIRED)
ENV=development
# Debug mode: true, false (REQUIRED)
DEBUG=true
# Use * for development or specific origins for production (REQUIRED)
BACKEND_CORS_ORIGINS=http://localhost,http://localhost:3000

# --- Docker / Compose Infrastructure ---
# Redis Connection String (REQUIRED)
REDIS_URL=redis://redis:6379/0

# --- Logging / Debugging ---
# Level: DEBUG, INFO, WARNING, ERROR, CRITICAL
LOG_LEVEL=DEBUG
PYTHONASYNCIODEBUG=1
PYTHONPATH=/app
