# ==========================================
# Tracing Objectives Backwards - Backend Env Template
# ==========================================

# --- API Settings ---
# Project branding
PROJECT_NAME="Tracing Objectives Backwards API"
# API version slug (e.g., v1, v2)
API_VERSION=v1

# --- Security ---
# Secret key for JWT/Session signing (REQUIRED in production)
# Generate with: openssl rand -hex 32
SECRET_KEY=change-me-in-production

# --- Infrastructure ---
# Environment: development, production, testing
ENV=development
# Debug mode (true/false)
DEBUG=true
# Allowed CORS origins (comma-separated)
BACKEND_CORS_ORIGINS=http://localhost,http://localhost:3000

# --- Storage ---
# Path for datasets and models
DATA_STORAGE_PATH=/app/storage

# --- Logging ---
# Level: DEBUG, INFO, WARNING, ERROR, CRITICAL
LOG_LEVEL=INFO

# Redis (e.g., redis://redis:6379/0 for Docker, redis://localhost:6379/0 for local)
REDIS_URL=redis://localhost:6379/0
