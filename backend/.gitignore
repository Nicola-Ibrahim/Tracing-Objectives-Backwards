# ==========================================
# Tracing Objectives Backwards - Backend Service Ignore
# ==========================================

# Byte-compiled / optimized / DLL files
__pycache__/
*.py[cod]
*$py.class
*.so

# Python Build & Distribution
/build/
/dist/
/*.egg-info/
/.eggs/
/lib/
/lib64/
/sdist/
/wheels/
/*.egg
MANIFEST

# Data & Storage (DOCKER VOLUMES)
/storage/
/data/
/models/
/contexts/
/diagnostics/
/reports/

# Python Tools Caches
.cache/
.tox/
.nox/
.coverage
.coverage.*
.hypothesis/
.pytest_cache/
.ruff_cache/
.mypy_cache/

# Runtime
db.sqlite3
db.sqlite3-journal
instance/
celerybeat-schedule
celerybeat.pid
*.manifest
*.spec

# Translations
*.mo
*.pot
