# ==========================================
# Tracing Objectives Backwards - Global Git Ignore
# ==========================================

# --- Truly Global (Safe to ignore everywhere) ---
node_modules/
__pycache__/
*.py[cod]
*$py.class
.DS_Store
.idea/
.vscode/
*.swp
*.swo
*.pem
*.log

# --- Root Specific (Anchored) ---
/.env
/.venv/
/venv/
/env/
/.python-version
/.cache/
/coverage/

# --- Tool Specific ---
.ruff_cache/
.pytest_cache/
.mypy_cache/
.ipynb_checkpoints/
